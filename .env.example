# Copy this file to .env and fill in your own keys.
# Never commit your real .env file or share API keys publicly.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Legacy Supabase projects can use VITE_SUPABASE_ANON_KEY instead.
VITE_SUPABASE_ANON_KEY=

# Server-side only. Used by `npm run supabase:init`; never expose this in browser code.
SUPABASE_DB_URL=

VITE_OPENAI_API_KEY=
